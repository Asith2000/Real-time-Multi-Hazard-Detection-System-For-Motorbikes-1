<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorPrimary">

    <!-- AppBar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorPrimaryDark"
        app:elevation="6dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/colorPrimaryDark"
            app:title="Road Hazard Map"
            app:titleTextColor="@color/white" />

        <!-- Hazard class legend strip -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/colorPrimary"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <!-- Pothole -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginEnd="18dp"
                    android:orientation="horizontal">
                    <View android:layout_width="12dp" android:layout_height="12dp"
                        android:background="@drawable/circle_pothole" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginStart="6dp" android:text="Pothole"
                        android:textColor="@color/colorPothole" android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Speed Bump -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginEnd="18dp"
                    android:orientation="horizontal">
                    <View android:layout_width="12dp" android:layout_height="12dp"
                        android:background="@drawable/circle_speedbump" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginStart="6dp" android:text="Speed Bump"
                        android:textColor="@color/colorSpeedBump" android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Crosswalk -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginEnd="18dp"
                    android:orientation="horizontal">
                    <View android:layout_width="12dp" android:layout_height="12dp"
                        android:background="@drawable/circle_crosswalk" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginStart="6dp" android:text="Crosswalk"
                        android:textColor="@color/colorCrosswalk" android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Road Debris -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <View android:layout_width="12dp" android:layout_height="12dp"
                        android:background="@drawable/circle_debris" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginStart="6dp" android:text="Road Debris"
                        android:textColor="@color/colorRoadDebris" android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>
        </HorizontalScrollView>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Google Map fragment — fills remaining space -->
    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="634dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    <!-- Proximity Alert Banner -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardHazardAlert"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="16dp"
        android:layout_marginBottom="88dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/colorAccent"
        app:cardCornerRadius="16dp"
        app:cardElevation="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠️"
                android:textSize="30sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvAlertTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hazard Ahead!"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAlertDetail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:alpha="0.9"
                    android:text="Pothole detected 50m ahead"
                    android:textColor="@color/white"
                    android:textSize="13sp" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnDismissAlert"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Dismiss"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="@color/white" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- FAB: centre on my location -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabMyLocation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:contentDescription="My Location"
        android:src="@android:drawable/ic_menu_mylocation"
        app:backgroundTint="@color/colorCard"
        app:elevation="6dp"
        app:tint="@color/colorAccent" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
